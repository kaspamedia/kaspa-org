{
  "name": "kaspa-org",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "check:node": "node scripts/check-node-version.mjs",
    "dev": "npm run -s check:node && next dev",
    "dev:lan": "npm run -s check:node && node scripts/dev-lan.mjs",
    "build": "npm run -s check:node && next build",
    "start": "npm run -s check:node && next start",
    "lint": "eslint",
    "types:check": "npm run -s check:node && next typegen && tsc --noEmit --incremental false",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "verify": "npm run lint && npm run format:check && npm run types:check && npm run build",
    "verify:full": "npm run verify && npm run test:e2e",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "PLAYWRIGHT_E2E_MODE=dev playwright test --headed",
    "test:e2e:ui": "PLAYWRIGHT_E2E_MODE=dev playwright test --ui",
    "prepare": "node .husky/install.mjs"
  },
  "dependencies": {
    "@createjs/core": "^2.0.0-beta.4",
    "@createjs/tweenjs": "^2.0.0-beta.4",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "pixi.js": "^8.18.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "flatted": "^3.4.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,css,scss,html,yml,yaml}": "prettier --write"
  }
}
